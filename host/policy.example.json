{
  "repo_root": "/home/rick/kestrel-host",
  "log_path": "~/.local/state/kestrel-repo-bridge/audit.jsonl",
  "protected_paths": [
    ".env",
    ".env.*",
    ".git/config",
    ".git/**",
    "**/__pycache__/**",
    "**/*.pyc",
    ".openclaw/**"
  ],
  "allowed_git_subcommands": [
    "status",
    "diff",
    "add",
    "commit",
    "branch"
  ],
  "rules": [
    {
      "id": "read-docs-src",
      "enabled": true,
      "action": "read_file",
      "path_globs": [
        "README.md",
        "docs/**",
        "runtime/**",
        "scripts/**",
        "training/**",
        "metadata/**",
        "evals/**",
        "prompts/**",
        "AGENTS.md",
        "IDENTITY.md",
        "SOUL.md",
        "TOOLS.md",
        "BOOTSTRAP.md"
      ],
      "mode": "auto_allow"
    }
  ],
  "command_rules": [
    {
      "id": "host-safe-pwd",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": [
        "."
      ],
      "argv0": "pwd",
      "pattern": "^pwd$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "host-safe-ls",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": [
        ".",
        "docs/**",
        "runtime/**",
        "scripts/**"
      ],
      "argv0": "ls",
      "pattern": "^ls( .*)?$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "host-safe-find",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": [
        ".",
        "docs/**",
        "runtime/**",
        "scripts/**"
      ],
      "argv0": "find",
      "pattern": "^find( .*)?$",
      "elevate": false,
      "mode": "ask"
    },
    {
      "id": "host-safe-git-status",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": [
        "."
      ],
      "argv0": "git",
      "pattern": "^git status( .*)?$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "host-safe-git-diff",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": [
        "."
      ],
      "argv0": "git",
      "pattern": "^git diff( .*)?$",
      "elevate": false,
      "mode": "auto_allow"
    }
  ]
}
