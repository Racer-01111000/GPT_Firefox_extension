{
  "repo_root": "/home/rick/GPT_Firefox_extension",
  "log_path": "~/.local/state/kestrel-repo-bridge/audit.jsonl",
  "protected_paths": [
    ".env",
    ".env.*",
    ".git/config",
    ".git/**",
    "**/__pycache__/**",
    "**/*.pyc",
    ".openclaw/**"
  ],
  "allowed_git_subcommands": [
    "status",
    "diff",
    "add",
    "commit",
    "branch",
    "pull",
    "push",
    "log"
  ],
  "rules": [
    {
      "id": "read-core-files",
      "enabled": true,
      "action": "read_file",
      "path_globs": [
        "README.md",
        "extension/**",
        "host/**",
        "scripts/**",
        "control/**"
      ],
      "mode": "auto_allow"
    }
  ],
  "command_rules": [
    {
      "id": "host-safe-pwd",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": [".", "extension/**", "host/**", "scripts/**", "control/**"],
      "argv0": "pwd",
      "pattern": "^pwd$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "host-safe-ls",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": [".", "extension/**", "host/**", "scripts/**", "control/**"],
      "argv0": "ls",
      "pattern": "^ls( .*)?$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "host-safe-grep",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": [".", "extension/**", "host/**", "scripts/**", "control/**"],
      "argv0": "grep",
      "pattern": "^grep( .*)?$",
      "elevate": false,
      "mode": "ask"
    },
    {
      "id": "host-safe-sed",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": [".", "extension/**", "host/**", "scripts/**", "control/**"],
      "argv0": "sed",
      "pattern": "^sed( .*)?$",
      "elevate": false,
      "mode": "ask"
    },
    {
      "id": "host-safe-git-status",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": ["."],
      "argv0": "git",
      "pattern": "^git status( .*)?$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "host-safe-git-diff",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": ["."],
      "argv0": "git",
      "pattern": "^git diff( .*)?$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "host-safe-git-log",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": ["."],
      "argv0": "git",
      "pattern": "^git log( .*)?$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "host-safe-python",
      "enabled": true,
      "action": "run_command",
      "target": "HOST",
      "cwd_globs": [".", "host/**", "scripts/**"],
      "argv0": "python3",
      "pattern": "^python3( .*)?$",
      "elevate": false,
      "mode": "ask"
    },
    {
      "id": "node-workload-pwd",
      "enabled": true,
      "action": "run_command",
      "target": "NODE_WORKLOAD",
      "cwd_globs": [".", "runtime/**", "control/**", "staging/**", "data/**", "scripts/**"],
      "argv0": "pwd",
      "pattern": "^pwd$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "node-workload-ls",
      "enabled": true,
      "action": "run_command",
      "target": "NODE_WORKLOAD",
      "cwd_globs": [".", "runtime/**", "control/**", "staging/**", "data/**", "scripts/**"],
      "argv0": "ls",
      "pattern": "^ls( .*)?$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "node-workload-git-status",
      "enabled": true,
      "action": "run_command",
      "target": "NODE_WORKLOAD",
      "cwd_globs": ["."],
      "argv0": "git",
      "pattern": "^git status( .*)?$",
      "elevate": false,
      "mode": "auto_allow"
    },
    {
      "id": "node-workload-git-diff",
      "enabled": true,
      "action": "run_command",
      "target": "NODE_WORKLOAD",
      "cwd_globs": ["."],
      "argv0": "git",
      "pattern": "^git diff( .*)?$",
      "elevate": false,
      "mode": "auto_allow"
    }
  ]
}
